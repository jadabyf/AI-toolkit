{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "defaults": {
      "type": "object",
      "properties": {
        "thresholds": {
          "type": "object",
          "properties": {
            "passScore": { "type": "number", "minimum": 0, "maximum": 100 },
            "warnScore": { "type": "number", "minimum": 0, "maximum": 100 }
          },
          "additionalProperties": false
        },
        "rules": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" },
              "params": { "type": "object", "additionalProperties": true }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "siteTypes": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "thresholds": {
            "type": "object",
            "properties": {
              "passScore": { "type": "number", "minimum": 0, "maximum": 100 },
              "warnScore": { "type": "number", "minimum": 0, "maximum": 100 }
            },
            "additionalProperties": false
          },
          "rules": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "params": { "type": "object", "additionalProperties": true }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
