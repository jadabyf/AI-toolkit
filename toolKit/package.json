{
  "name": "ai-web-research-toolkit",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "bin": {
    "toolkit": "dist/toolkit.js",
    "research": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/toolkit.ts",
    "lint": "tsc -p tsconfig.test.json --noEmit",
    "test": "vitest run",
    "test:status": "node scripts/test-status.cjs",
    "test:verbose": "npm test -- --reporter=verbose",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:debug": "vitest --inspect-brk --inspect --single-thread",
    "check": "npm run lint && npm run build && npm run test",
    "research": "tsx src/toolkit.ts research run",
    "research:design": "tsx src/designResearchCli.ts",
    "research:examples": "tsx examples/research-examples.ts",
    "research:cli": "tsx src/toolkit.ts"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "dotenv": "^16.4.5",
    "openai": "^4.104.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "tsx": "^4.7.1",
    "typescript": "^5.6.3",
    "vitest": "^4.0.18"
  }
}
