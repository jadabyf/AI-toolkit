{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Research CLI (gate)",
      "program": "${workspaceFolder}/dist/cli.js",
      "args": ["gate", "--in", "out", "--out", "out/gate.json", "--format", "md"],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "preLaunchTask": "build",
      "console": "integratedTerminal"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Research CLI (run)",
      "program": "${workspaceFolder}/dist/cli.js",
      "args": ["run", "--siteType", "newsletter", "--out", "out"],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "preLaunchTask": "build",
      "console": "integratedTerminal"
    }
  ]
}
